# 云雾模型
YUNWU_API_URL=https://yunwu.ai
YUNWU_API_KEY=your-yunwu-api-key
YUNWU_MODEL=gemini-3.1-flash-image-preview

# VectorEngine 模型（可选）
VECTORENGINE_API_URL=https://api.vectorengine.ai
VECTORENGINE_API_KEY=your-vectorengine-api-key
VECTORENGINE_MODEL=gemini-3.1-flash-image-preview

# Pockgo / OpenAI 兼容模型（可选）
POCKGO_API_URL=https://newapi.aicohere.org/v1/chat/completions
POCKGO_API_KEY=your-pockgo-api-key
POCKGO_MODEL=gemini-3.1-flash-image-preview

# 阿里云 OSS
ALI_OSS_REGION=oss-cn-hangzhou
ALI_OSS_ACCESS_KEY_ID=your-oss-access-key-id
ALI_OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
ALI_OSS_BUCKET=your-oss-bucket

# 可选：自定义 CDN 域名，例如 https://cdn.example.com
ALI_OSS_CUSTOM_DOMAIN=

# 可选：手动开启 OSS 传输加速
ALI_OSS_USE_ACCELERATE=false
